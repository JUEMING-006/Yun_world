<t-popup visible="{{visible}}" placement="bottom" bind:visible-change="onClose">
  <view class="agent-actions-sheet" catchtap="stopPropagation">
    <view class="sheet-header">
      <text class="sheet-title">{{agentName || 'AI Assistant'}}</text>
      <view class="sheet-close" bindtap="onClose"><t-icon name="close" size="40rpx" /></view>
    </view>
    <view class="actions-list">
      <view wx:for="{{actions}}" wx:key="id" class="action-item" data-id="{{item.id}}" bindtap="onActionClick">
        <view class="action-icon-wrap"><t-icon name="{{item.icon}}" size="44rpx" color="var(--accent-color)" /></view>
        <view class="action-info">
          <text class="action-title">{{item.title}}</text>
          <text class="action-desc">{{item.desc}}</text>
        </view>
        <t-icon name="chevron-right" size="32rpx" color="var(--text-placeholder)" />
      </view>
    </view>
  </view>
</t-popup>
