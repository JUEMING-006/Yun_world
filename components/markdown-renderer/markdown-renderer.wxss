/**
 * Markdown 渲染样式
 * 对应 Kuikly: ChMarkdown.kt 的样式
 */

.markdown-body {
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text-primary);
}

/* ── 标题 ── */
.md-heading {
  display: block;
  font-weight: 700;
  margin: 16rpx 0 8rpx;
  line-height: 1.4;
}

.md-h1 { font-size: 40rpx; margin-top: 24rpx; }
.md-h2 { font-size: 36rpx; margin-top: 20rpx; }
.md-h3 { font-size: 32rpx; margin-top: 16rpx; }
.md-h4 { font-size: 30rpx; }
.md-h5 { font-size: 28rpx; }
.md-h6 { font-size: 26rpx; color: var(--text-secondary); }

/* ── 段落 ── */
.md-paragraph {
  display: block;
  margin: 8rpx 0;
  word-break: break-word;
}

/* ── 代码块 ── */
.md-code-block {
  background-color: #1e1e1e;
  border-radius: 12rpx;
  margin: 16rpx 0;
  overflow: hidden;
}

.md-code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #2d2d2d;
}

.md-code-lang {
  font-size: 22rpx;
  color: #999;
}

.md-code-copy {
  padding: 4rpx 8rpx;
}

.md-code-content {
  padding: 16rpx;
  overflow-x: auto;
}

.md-code-text {
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
  font-size: 24rpx;
  line-height: 1.5;
  color: #d4d4d4;
  white-space: pre;
}

/* ── 引用 ── */
.md-blockquote {
  border-left: 6rpx solid var(--accent-color);
  padding: 8rpx 16rpx;
  margin: 12rpx 0;
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 0 8rpx 8rpx 0;
}

.md-blockquote-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-style: italic;
}

/* ── 列表 ── */
.md-list {
  margin: 8rpx 0;
  padding-left: 24rpx;
}

.md-list-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin: 4rpx 0;
}

.md-list-bullet {
  flex-shrink: 0;
  color: var(--text-secondary);
  font-size: 30rpx;
  line-height: 1.7;
}

.md-list-number {
  flex-shrink: 0;
  color: var(--text-secondary);
  font-size: 28rpx;
  min-width: 36rpx;
}

.md-list-text {
  flex: 1;
  word-break: break-word;
}
