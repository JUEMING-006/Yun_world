<!--
  Markdown 渲染器
  对应 Kuikly: ChMarkdown.kt
  将解析后的块列表渲染为原生 WXML
-->
<view class="markdown-body">
  <block wx:for="{{blocks}}" wx:key="index">

    <!-- 标题 -->
    <text wx:if="{{item.type === 'heading'}}" class="md-heading md-h{{item.level}}" user-select>{{item.text}}</text>

    <!-- 段落 -->
    <text wx:elif="{{item.type === 'paragraph'}}" class="md-paragraph" user-select space="nbsp">{{item.text}}</text>

    <!-- 代码块 -->
    <view wx:elif="{{item.type === 'code'}}" class="md-code-block">
      <view class="md-code-header">
        <text class="md-code-lang">{{item.lang || 'code'}}</text>
        <view class="md-code-copy" data-content="{{item.content}}" bindtap="onCopyCode">
          <t-icon name="copy" size="28rpx" color="#999" />
        </view>
      </view>
      <view class="md-code-content">
        <text class="md-code-text" user-select>{{item.content}}</text>
      </view>
    </view>

    <!-- 引用 -->
    <view wx:elif="{{item.type === 'blockquote'}}" class="md-blockquote">
      <text class="md-blockquote-text" user-select>{{item.text}}</text>
    </view>

    <!-- 无序列表 -->
    <view wx:elif="{{item.type === 'ul'}}" class="md-list">
      <view wx:for="{{item.items}}" wx:for-item="li" wx:key="*this" class="md-list-item">
        <text class="md-list-bullet">•</text>
        <text class="md-list-text" user-select space="nbsp">{{li}}</text>
      </view>
    </view>

    <!-- 有序列表 -->
    <view wx:elif="{{item.type === 'ol'}}" class="md-list">
      <view wx:for="{{item.items}}" wx:for-item="li" wx:for-index="liIdx" wx:key="*this" class="md-list-item">
        <text class="md-list-number">{{liIdx + 1}}.</text>
        <text class="md-list-text" user-select space="nbsp">{{li}}</text>
      </view>
    </view>

  </block>
</view>
