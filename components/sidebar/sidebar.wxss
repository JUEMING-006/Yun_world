/**
 * Sidebar styles
 * Kuikly dp = miniprogram px (1:1)
 */

.sidebar-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.25);
  z-index: 100;
}

.sidebar-content {
  position: absolute;
  top: 0; 
  left: 0;
  width: 74%;
  height: 100%;
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  flex-direction: column;
  animation: slideIn 0.3s ease;
  padding: 8px 16px 0px;
}

@keyframes slideIn {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}

/* Nav: padding(left=16f, right=16f), height=48f+statusBarHeight */
.sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sidebar-title {
  font-size: 26px;
  font-weight: 700;
  color: #333;
}

.sidebar-header-spacer { flex: 1; }

/* Tools: height(38f), borderRadius(22f), padding(4f) */
.sidebar-tools {
  display: flex;
  align-items: center;
  height: 38px;
  border-radius: 22px;
  background-color: #fff;
  padding: 4px;
  box-shadow: 0 0 10px #f0f0ee;
}

.tool-btn {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 2px;
}

.tool-avatar {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  margin: 6px;
}

/* New chat button */
.new-chat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  background-color: var(--accent-color);
  border-radius: 999px;
  padding: 8px 0;
  margin: 0 8px 4px;
}

.new-chat-text {
  color: #fff;
  font-size: 15px;
  font-weight: 500;
}

/* Agent list */
.agent-list {
  flex: 1;
  padding: 0 0;
  margin-top: 12px;
}

.section-title {
  font-size: 12px;
  font-weight: 700;
  color: #999;
}

/* Agent item: padding(8f,16f) */
.agent-item {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 16px;
  border-radius: var(--radius-md);
  margin-bottom: 1px;
}

.agent-item.active {
  background-color: var(--card-bg);
}

.agent-avatar-wrap { flex-shrink: 0; }

/* Avatar: size(36f,36f), borderRadius(18f) */
.agent-avatar {
  width: 36px;
  height: 36px;
  border-radius: 18px;
}

.agent-avatar.default {
  background-color: var(--accent-color);
  display: flex;
  justify-content: center;
  align-items: center;
}

.agent-avatar-text {
  color: #fff;
  font-size: 14px;
  font-weight: 700;
}

.agent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1px;
  overflow: hidden;
}

/* Name: fontSize(18f) */
.agent-name {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Desc: fontSize(13f), color=#999999 */
.agent-desc {
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Bottom function bar: height(42f) */
.sidebar-footer {
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: row;
  overflow: hidden;
  align-items: center;
  justify-content: space-between;
  height: 48px;
}

.func-scroll {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-width: 0;
  box-shadow: 0 0 5px #f0f0ee;
  border-radius: 24px;
  overflow: hidden;
}

/* Function bar: height(38f), borderRadius(22f), padding(4f) */
.function-bar {
  display: flex;
  align-items: center;
  height: 38px;
  border-radius: 22px;
  background-color: #fff;
  padding: 4px;
  white-space: nowrap;
  gap: 4px;
}

.func-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  height: 32px;
  padding: 4px 10px;
  border-radius: 999px;
  color: #999;
  gap: 4px;
  flex-shrink: 0;
}

.func-btn.active {
  background-color: var(--card-bg-button);
  color: #333;
}

.func-text {
  font-size: 12px;
  line-height: 14px;
}

.more-btn {
  width: 38px;
  height: 38px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 5px #f0f0ee;
  border-radius: 100%;
  margin-left: 8px;
}

.empty-agents {
  display: flex;
  justify-content: start;
  align-items: start;
  margin-top: 12px;
}

.empty-text {
  font-size: 14px;
  color: var(--text-placeholder);
}
