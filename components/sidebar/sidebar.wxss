/**
 * Sidebar styles
 * Kuikly dp = miniprogram px (1:1)
 */

.sidebar-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.25);
  z-index: 100;
}

.sidebar-content {
  position: absolute;
  top: 0; left: 0;
  width: 80%;
  max-width: 300px;
  height: 100%;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}

/* Nav: padding(left=16f, right=16f), height=48f+statusBarHeight */
.sidebar-header {
  display: flex;
  align-items: center;
  padding: 8px 16px 4px;
  padding-top: calc(env(safe-area-inset-top) + 8px);
}

.sidebar-title {
  font-size: 14px;
  font-weight: 700;
  color: #333;
}

.sidebar-header-spacer { flex: 1; }

/* Tools: height(38f), borderRadius(22f), padding(4f) */
.sidebar-tools {
  display: flex;
  align-items: center;
  height: 38px;
  border-radius: 22px;
  background-color: #fff;
  padding: 4px;
  box-shadow: 0 0 10px #f0f0ee;
}

.tool-btn {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 2px;
}

.tool-avatar {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  margin: 6px;
}

/* New chat button */
.new-chat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  background-color: var(--accent-color);
  border-radius: 999px;
  padding: 8px 0;
  margin: 0 8px 4px;
}

.new-chat-text {
  color: #fff;
  font-size: 15px;
  font-weight: 500;
}

/* Agent list */
.agent-list {
  flex: 1;
  padding: 0 4px;
}

.section-title {
  font-size: 7px;
  font-weight: 700;
  color: #999;
  margin: 10px 8px 4px;
}

/* Agent item: padding(8f,16f) */
.agent-item {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 16px;
  border-radius: var(--radius-md);
  margin-bottom: 1px;
}

.agent-item.active {
  background-color: var(--card-bg);
}

.agent-avatar-wrap { flex-shrink: 0; }

/* Avatar: size(36f,36f), borderRadius(18f) */
.agent-avatar {
  width: 36px;
  height: 36px;
  border-radius: 18px;
}

.agent-avatar.default {
  background-color: var(--accent-color);
  display: flex;
  justify-content: center;
  align-items: center;
}

.agent-avatar-text {
  color: #fff;
  font-size: 14px;
  font-weight: 700;
}

.agent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1px;
  overflow: hidden;
}

/* Name: fontSize(18f) */
.agent-name {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Desc: fontSize(13f), color=#999999 */
.agent-desc {
  font-size: 13px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Bottom function bar: height(42f) */
.sidebar-footer {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  height: 42px;
  padding: 0 16px;
  padding-bottom: calc(6px + env(safe-area-inset-bottom));
}

/* Function bar: height(38f), borderRadius(22f), padding(4f) */
.function-bar {
  flex: 1;
  display: flex;
  align-items: center;
  height: 38px;
  border-radius: 22px;
  background-color: #fff;
  padding: 4px;
  box-shadow: 0 0 10px #f0f0ee;
}

.func-btn {
  height: 32px;
  padding: 6px;
  border-radius: 999px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 3px;
}

.func-btn:first-child {
  background-color: var(--card-bg-button);
}

.more-btn {
  width: 38px;
  height: 38px;
  margin-left: 4px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 5px #f0f0ee;
}

.empty-agents {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px 0;
}

.empty-text {
  font-size: 14px;
  color: var(--text-placeholder);
}
