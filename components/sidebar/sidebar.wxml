<view wx:if="{{visible}}" class="sidebar-mask" bindtap="onMaskClick">
  <view class="sidebar-content" catchtap="stopPropagation" style="padding-top: {{statusBarHeight}}px; padding-bottom: {{safeBottom + 6}}px">
    <!-- Nav: Lumina + tools -->
    <view class="sidebar-header">
      <text class="sidebar-title">Lumina</text>
      <view class="sidebar-tools">
        <view class="tool-btn" bindtap="onSearchTap">
          <t-icon name="search" size="36rpx" color="#333" />
        </view>
        <view class="tool-btn">
          <t-icon name="notification" size="36rpx" color="#333" />
        </view>
        <image class="tool-avatar" src="{{userAvatar || '/images/avatar_example.webp'}}" mode="aspectFill" />
      </view>
    </view>

    <!-- New chat -->
    <!-- <view class="new-chat-btn" bindtap="onNewChat">
      <t-icon name="add" size="40rpx" color="#fff" />
      <text class="new-chat-text">New Chat</text>
    </view> -->

    <!-- Agent list -->
    <scroll-view class="agent-list" scroll-y="{{true}}">
      <text class="section-title">虚拟伙伴</text>
      <view wx:for="{{agents}}" wx:key="agentId" class="agent-item {{item.agentId === currentAgentId ? 'active' : ''}}" data-id="{{item.agentId}}" bindtap="onSelectAgent">
        <view class="agent-avatar-wrap">
          <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="agent-avatar" mode="aspectFill" />
          <view wx:else class="agent-avatar default"><text class="agent-avatar-text">{{item.name[0] || 'A'}}</text></view>
        </view>
        <view class="agent-info">
          <text class="agent-name">{{item.name}}</text>
          <text class="agent-desc">{{item.description}}</text>
        </view>
      </view>
      <view wx:if="{{agents.length === 0}}" class="empty-agents">
        <text class="empty-text">暂时还没有伙伴哦</text>
      </view>
    </scroll-view>

    <!-- Bottom function bar -->
    <view class="sidebar-footer">
      <scroll-view class="func-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
        <view class="function-bar">
          <view class="func-btn {{selectedFunc === 'psych' ? 'active' : ''}}" data-func="psych" bindtap="onSelectFunc">
            <t-icon name="heart" size="36rpx" />
            <text class="func-text">心理测评</text>
          </view>
          <view class="func-btn {{selectedFunc === 'knowledge' ? 'active' : ''}}" data-func="knowledge" bindtap="onSelectFunc">
            <t-icon name="file" size="36rpx" />
            <text class="func-text">心理知识</text>
          </view>
          <view class="func-btn {{selectedFunc === 'circle' ? 'active' : ''}}" data-func="circle" bindtap="onSelectFunc">
            <t-icon name="robot-2" size="36rpx" />
            <text class="func-text">智能玩偶</text>
          </view>
          <view class="func-btn {{selectedFunc === 'video' ? 'active' : ''}}" data-func="video" bindtap="onSelectFunc">
            <t-icon name="ai-video" size="36rpx" />
            <text class="func-text">AI剧场</text>
          </view>
          <view class="func-btn {{selectedFunc === 'setting' ? 'active' : ''}}" data-func="setting" bindtap="onSelectFunc">
            <t-icon name="mail" size="36rpx" />
            <text class="func-text">心理信箱</text>
          </view>
        </view>
      </scroll-view>
      <view class="more-btn" bind:tap="onMaskClick">
        <t-icon name="close" size="36rpx" color="#333" />
      </view>
    </view>
  </view>
</view>