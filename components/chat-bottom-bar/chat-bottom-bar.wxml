<!--
  聊天底部输入栏
  对应 Kuikly: ChatBottomBar.kt
-->
<view class="bottom-bar">

  <!-- 模式切换栏 -->
  <view class="mode-bar">
    <view
      class="mode-btn {{isThinkingMode ? 'active' : ''}}"
      bindtap="onToggleThinking"
    >
      <t-icon name="ai-education" size="32rpx" color="{{isThinkingMode ? '#fff' : 'var(--text-secondary)'}}" />
      <text class="mode-text">深度思考</text>
    </view>

    <view
      class="mode-btn {{isSearchMode ? 'active' : ''}}"
      bindtap="onToggleSearch"
    >
      <t-icon name="ai-search" size="32rpx" color="{{isSearchMode ? '#fff' : 'var(--text-secondary)'}}" />
      <text class="mode-text">联网搜索</text>
    </view>
  </view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <!-- 附件按钮 -->
    <view class="attach-btn" bindtap="onAttach">
      <t-icon name="add-circle" size="48rpx" color="var(--text-secondary)" />
    </view>

    <!-- 输入框 -->
    <view class="input-wrap">
      <input
        class="text-input"
        type="text"
        placeholder="{{placeholder}}"
        placeholder-class="placeholder"
        value="{{inputValue}}"
        confirm-type="send"
        cursor-spacing="20"
        adjust-position="{{true}}"
        bindinput="onInput"
        bindfocus="onFocus"
        bindblur="onBlur"
        bindconfirm="onSend"
      />
    </view>

    <!-- 发送按钮 -->
    <view
      class="send-btn"
      bindtap="{{ inputValue ? 'onSend' : '' }}"
    >
      <t-icon
        wx:if="{{!isSending}}"
        name="call"
        size="40rpx"
        color="#fff"
      />
      <t-icon
        wx:else
        name="send"
        size="40rpx"
        color="{{inputValue ? '#fff' : '#ccc'}}"
      />
    </view>
  </view>

</view>
