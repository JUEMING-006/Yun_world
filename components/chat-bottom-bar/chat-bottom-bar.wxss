/**
 * 底部输入栏样式
 * 对应 Kuikly: ChatBottomBar.kt
 */

.bottom-bar {
  background-color: var(--chat-bottom-bar-bg);
  border-top: 2rpx solid var(--border-bottom-bar);
  padding: 0px 0px;
}

/* ── 模式切换 ── */
.mode-bar {
  display: flex;
  gap: 12px;
  height: 48px;
  margin-bottom: 12rpx;
}

.mode-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  height: 32px;
  padding: 8px 12px;
  border-radius: 99rpx;
  background-color: transparent;
  border: 1rpx solid transparent;
}

.mode-btn.active {
  background-color: var(--accent-color);
  border-color: var(--accent-color);
}

.mode-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.mode-btn.active .mode-text {
  color: #fff;
}

/* ── 输入栏 ── */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.attach-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.input-wrap {
  flex: 1;
  background-color: #fff;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  min-height: 64rpx;
  display: flex;
  align-items: center;
}

.text-input {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.4;
  color: var(--text-primary);
}

.placeholder {
  color: var(--text-placeholder);
  font-size: 30rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: black;
  display: flex;
  justify-content: center;
  align-items: center;
}

