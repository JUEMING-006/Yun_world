<!--
  自定义顶部导航栏
  对应 Kuikly: AppTopBar 组件
-->
<view class="top-bar" style="background-color: {{bgColor}}; padding-top: {{statusBarHeight}}px;">

  <view class="nav-content" style="height: {{navHeight}}px;">

    <!-- 左侧返回按钮 -->
    <view class="nav-left" wx:if="{{showBack}}" bindtap="onBack">
      <t-icon name="chevron-left" size="40rpx" color="#333" />
    </view>

    <!-- 中间标题 -->
    <view class="nav-center">
      <text class="nav-title">{{title}}</text>
    </view>

    <!-- 右侧按钮 -->
    <view class="nav-right">
      <view
        wx:for="{{rightButtons}}"
        wx:key="index"
        class="nav-right-btn"
        data-index="{{index}}"
        bindtap="onRightBtn"
      >
        <t-icon wx:if="{{item.icon}}" name="{{item.icon}}" size="36rpx" color="#333" />
        <text wx:if="{{item.text}}" class="nav-right-text">{{item.text}}</text>
      </view>
    </view>

  </view>

</view>
