.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.lang-list{padding:24rpx}.lang-item{display:flex;align-items:center;gap:16rpx;padding:28rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:2rpx;border:2rpx solid transparent}.lang-item.active{border-color:var(--accent-color)}.lang-native{flex:1;font-size:32rpx;font-weight:500}.lang-label{font-size:24rpx;color:var(--text-secondary)}
