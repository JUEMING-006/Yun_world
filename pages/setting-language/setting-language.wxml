<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="语言" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="lang-list">
      <view wx:for="{{languages}}" wx:key="id" class="lang-item {{currentLanguage===item.id?'active':''}}" data-id="{{item.id}}" bindtap="onSelectLanguage">
        <text class="lang-native">{{item.native}}</text>
        <text class="lang-label">{{item.label}}</text>
        <t-icon wx:if="{{currentLanguage===item.id}}" name="check" size="36rpx" color="var(--accent-color)" />
      </view>
    </view>
  </scroll-view>
</view>
