.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.tabs{display:flex;border-bottom:1rpx solid var(--divider-color)}.tab{flex:1;text-align:center;padding:24rpx;font-size:28rpx;color:var(--text-secondary)}.tab.active{color:var(--accent-color);font-weight:700;border-bottom:4rpx solid var(--accent-color)}.content{flex:1}.loading,.empty{display:flex;justify-content:center;padding:80rpx 0;font-size:26rpx;color:var(--text-secondary)}.scale-list,.history-list{padding:16rpx 24rpx}.scale-card{display:flex;align-items:center;gap:16rpx;padding:28rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:12rpx}.scale-info{flex:1}.scale-name{font-size:30rpx;font-weight:500;display:block}.scale-desc{font-size:24rpx;color:var(--text-secondary);display:block;margin:4rpx 0}.scale-meta{display:flex;gap:24rpx;font-size:22rpx;color:var(--text-placeholder)}.history-card{padding:24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:12rpx}.history-name{font-size:30rpx;font-weight:500;display:block}.history-meta{display:flex;gap:16rpx;margin:8rpx 0}.history-score{font-size:26rpx;color:var(--accent-color)}.history-level{font-size:26rpx}.history-time{font-size:22rpx;color:var(--text-placeholder)}