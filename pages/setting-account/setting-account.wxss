.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.info-card{margin:24rpx;padding:24rpx;background:var(--card-bg);border-radius:var(--radius-md);display:flex;justify-content:space-between}.label{font-size:26rpx;color:var(--text-secondary)}.value{font-size:26rpx;font-weight:500}.menu-list{margin:0 24rpx}.menu-item{display:flex;justify-content:space-between;align-items:center;padding:28rpx 24rpx;background:var(--card-bg);border-bottom:1rpx solid var(--divider-color)}.menu-item:first-child{border-radius:var(--radius-md) var(--radius-md) 0 0}.menu-item:last-child{border-radius:0 0 var(--radius-md) var(--radius-md);border-bottom:none}.menu-item.danger text{color:var(--error-color)}.delete-sheet{padding:32rpx;background:var(--bg-color);border-radius:32rpx 32rpx 0 0}.sheet-title{font-size:34rpx;font-weight:700;display:block;margin-bottom:16rpx}.sheet-warn{font-size:26rpx;color:var(--error-color);display:block;margin-bottom:24rpx}