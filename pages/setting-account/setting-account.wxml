<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="Lumina 账号" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="info-card"><text class="label">Lumina ID</text><text class="value">{{luminaId}}</text></view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToRealName"><text>实名认证</text><t-icon name="chevron-right" size="32rpx" color="#999" /></view>
      <view class="menu-item" bindtap="goToDevices"><text>登录设备</text><t-icon name="chevron-right" size="32rpx" color="#999" /></view>
      <view class="menu-item danger" bindtap="onDeleteAccount"><text>注销账号</text><t-icon name="chevron-right" size="32rpx" color="var(--error-color)" /></view>
    </view>
  </scroll-view>
  <t-popup visible="{{showDeleteConfirm}}" placement="bottom" bind:visible-change="onCloseDelete">
    <view class="delete-sheet">
      <text class="sheet-title">注销账号</text>
      <text class="sheet-warn">⚠️ 注销后所有数据将被永久删除，无法恢复</text>
      <view wx:if="{{deleteStep===1}}">
        <t-input placeholder="请输入注册手机号" type="number" value="{{deletePhone}}" bind:change="onDeletePhoneInput" />
        <t-button theme="danger" block="{{true}}" loading="{{isSending}}" bind:tap="onSendDeleteCode" style="margin-top:24rpx">发送验证码</t-button>
      </view>
      <view wx:else>
        <t-input placeholder="请输入验证码" type="number" value="{{deleteCode}}" bind:change="onDeleteCodeInput" />
        <t-button theme="danger" block="{{true}}" loading="{{isDeleting}}" bind:tap="onConfirmDelete" style="margin-top:24rpx">确认注销</t-button>
      </view>
    </view>
  </t-popup>
</view>