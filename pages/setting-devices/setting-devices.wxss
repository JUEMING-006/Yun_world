.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.loading,.empty{display:flex;justify-content:center;padding:80rpx 0;font-size:26rpx;color:var(--text-secondary)}.device-list{padding:16rpx 24rpx}.device-card{display:flex;justify-content:space-between;align-items:center;padding:24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:12rpx}.device-info{display:flex;align-items:center;gap:16rpx}.device-text{display:flex;flex-direction:column;gap:4rpx}.device-name{font-size:28rpx;font-weight:500}.device-time{font-size:22rpx;color:var(--text-secondary)}.device-kick{padding:8rpx 24rpx;border-radius:99rpx;border:2rpx solid var(--error-color);color:var(--error-color);font-size:24rpx}