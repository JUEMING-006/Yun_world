<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="登录设备" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view wx:if="{{isLoading}}" class="loading"><text>加载中...</text></view>
    <view wx:elif="{{devices.length===0}}" class="empty"><t-empty description="暂无登录设备" /></view>
    <view wx:else class="device-list">
      <view wx:for="{{devices}}" wx:key="id" class="device-card">
        <view class="device-info"><t-icon name="smartphone" size="40rpx" color="var(--accent-color)" /><view class="device-text"><text class="device-name">{{item.deviceName}}</text><text class="device-time">最后活跃: {{item.lastActive}}</text></view></view>
        <view class="device-kick" data-id="{{item.id}}" bindtap="onKickDevice"><text>下线</text></view>
      </view>
    </view>
  </scroll-view>
</view>