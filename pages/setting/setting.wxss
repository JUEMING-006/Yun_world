/**
 * Setting page styles
 * Kuikly dp = miniprogram px (1:1)
 */

.setting-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-color);
}

/* Scroller: padding(top=100f, bottom=16f) */
.setting-scroll {
  flex: 1;
  padding-top: 100px;
  padding-bottom: 16px;
}

/* User card: width=pageViewWidth-32f, borderRadius(20f), padding(20f,24f) */
.user-card {
  width: calc(100% - 32px);
  align-self: center;
  background-color: #F5F5F5;
  border-radius: 20px;
  padding: 24px 20px;
  border: 1px solid #E0E0E0;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Avatar: size(80f,80f), borderRadius(40f) */
.user-avatar {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  align-self: center;
}

.user-avatar.default {
  background-color: var(--accent-color);
  display: flex;
  justify-content: center;
  align-items: center;
}

.user-avatar-text {
  color: #fff;
  font-size: 24px;
  font-weight: 700;
}

/* Nickname: fontSize(20f), fontWeightBold, marginTop(12f), marginBottom(4f) */
.user-nickname {
  font-size: 20px;
  font-weight: 700;
  margin-top: 12px;
  margin-bottom: 4px;
  color: #000;
  align-self: center;
}

.user-id {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.user-plan {
  font-size: 11px;
  color: var(--accent-color);
  background-color: rgba(74, 144, 217, 0.1);
  padding: 2px 8px;
  border-radius: 999px;
  align-self: center;
  margin-top: 4px;
}

/* Edit button: height(32f), padding(left/right=16f), fontSize(14f), borderRadius(16f) */
.edit-profile-btn {
  height: 32px;
  padding: 0 16px;
  background-color: transparent;
  border: 1px solid #E0E0E0;
  border-radius: 16px;
  display: flex;
  justify-content: center;
  align-items: center;
  align-self: center;
  margin-top: 8px;
}

.edit-profile-btn text {
  font-size: 14px;
  font-weight: 600;
  color: #666;
}

/* Group title */
.group-title {
  font-size: 13px;
  color: var(--text-secondary);
  padding: 8px 16px 4px;
  font-weight: 500;
}

/* Group content: borderRadius(20f) */
.group-content {
  background-color: #F5F5F5;
  border-radius: 20px;
  margin: 4px 16px 8px;
  border: 1px solid #E0E0E0;
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid #eee;
}

.list-item:last-child { border-bottom: none; }

.item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.item-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.item-subtitle {
  font-size: 12px;
  color: var(--text-secondary);
}

/* Logout: borderRadius(20f), padding(16f), margin(16f,16f,8f,20f) */
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px;
  margin: 8px 16px 20px;
  background-color: #F5F5F5;
  border-radius: 20px;
  border: 1px solid #E0E0E0;
}

.logout-text {
  font-size: 16px;
  font-weight: 500;
  color: #E53935;
}

/* Edit modal */
.edit-modal {
  background-color: #fff;
  border-radius: 32px 32px 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #eee;
}

.edit-modal-title {
  font-size: 16px;
  font-weight: 700;
}

.edit-modal-actions {
  display: flex;
  gap: 8px;
}

.edit-modal-save,
.edit-modal-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 10px #f0f0ee;
}

.edit-avatar-section {
  display: flex;
  justify-content: center;
  padding: 16px 0;
}

.edit-avatar {
  width: 80px;
  height: 80px;
  border-radius: 40px;
}

.edit-nickname-section {
  padding: 0 20px 16px;
}

.nickname-input {
  height: 48px;
  font-size: 16px;
  text-align: center;
  font-weight: 500;
  color: #333;
  border: 1px solid #E0E0E0;
  border-radius: 12px;
  padding: 0 12px;
}

.nickname-placeholder {
  color: #999;
  font-size: 16px;
}

.version-info {
  text-align: center;
  padding: 16px 0 32px;
  font-size: 12px;
  color: var(--text-placeholder);
}
