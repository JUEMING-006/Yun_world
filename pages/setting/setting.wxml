<view class="setting-page">
  <top-bar title="设置" show-back="{{true}}" bg-color="var(--bg-color)" bind:back="onBack" />
  <scroll-view class="setting-scroll" scroll-y>
    <!-- User card -->
    <view class="user-card">
      <image class="user-avatar" src="{{avatarUrl || '/images/avatar_example.webp'}}" mode="aspectFill" />
      <text class="user-nickname">{{nickname}}</text>
      <view class="edit-profile-btn" bindtap="onEditProfile"><text>编辑个人资料</text></view>
    </view>
    <!-- Setting list groups -->
    <block wx:for="{{listData}}" wx:for-item="group" wx:key="listTitle">
      <view wx:if="{{group.listTitle}}" class="group-title">{{group.listTitle}}</view>
      <view class="group-content">
        <view wx:for="{{group.content}}" wx:for-item="item" wx:key="id" class="list-item" data-title="{{item.itemTitle}}" data-url="{{item.url}}" bindtap="onItemClick">
          <view class="item-left">
            <text class="item-title">{{item.itemTitle}}</text>
            <text wx:if="{{item.subTitle}}" class="item-subtitle">{{item.subTitle}}</text>
          </view>
          <t-icon name="chevron-right" size="32rpx" color="var(--text-placeholder)" />
        </view>
      </view>
    </block>
    <!-- Logout button: borderRadius(20f)=40px, padding(16f)=32px, margin(16f,16f,8f,20f) -->
    <view class="logout-btn" bindtap="onLogout">
      <t-icon name="logout" size="44rpx" color="#E53935" />
      <text class="logout-text">退出登录</text>
    </view>
  </scroll-view>
  <!-- Edit profile modal -->
  <t-popup visible="{{showEditModal}}" placement="bottom" bind:visible-change="onCloseEditModal">
    <view class="edit-modal">
      <view class="edit-modal-header">
        <text class="edit-modal-title">编辑个人资料</text>
        <view class="edit-modal-actions">
          <view class="edit-modal-save" bindtap="onSaveNickname"><t-icon name="check" size="40rpx" color="var(--primary-color)" /></view>
          <view class="edit-modal-close" bindtap="onCloseEditModal"><t-icon name="close" size="40rpx" /></view>
        </view>
      </view>
      <view class="edit-avatar-section">
        <image class="edit-avatar" src="{{avatarUrl || '/images/avatar_example.webp'}}" mode="aspectFill" bindtap="onChooseAvatar" />
      </view>
      <view class="edit-nickname-section">
        <input class="nickname-input" placeholder="请输入新昵称" placeholder-class="nickname-placeholder" value="{{nicknameInput}}" maxlength="{{20}}" bindinput="onNicknameInput" bindconfirm="onSaveNickname" />
      </view>
    </view>
  </t-popup>
</view>
