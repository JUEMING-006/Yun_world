.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1;padding:24rpx 32rpx}.type-row{display:flex;gap:16rpx;margin-bottom:24rpx}.type-btn{flex:1;text-align:center;padding:20rpx;border-radius:var(--radius-md);background:var(--card-bg);font-size:28rpx;border:2rpx solid transparent}.type-btn.active{border-color:var(--accent-color);color:var(--accent-color)}.form-area{margin-bottom:32rpx}.submit-area{margin-top:24rpx}