<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="反馈与帮助" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="type-row">
      <view class="type-btn {{feedbackType==='error_report'?'active':''}}" data-type="error_report" bindtap="onTypeSelect">🐛 问题反馈</view>
      <view class="type-btn {{feedbackType==='suggestion'?'active':''}}" data-type="suggestion" bindtap="onTypeSelect">💡 建议</view>
    </view>
    <view class="form-area">
      <t-textarea placeholder="请详细描述您遇到的问题或建议..." value="{{content}}" maxlength="{{1000}}" bind:change="onContentInput" style="min-height:300rpx" />
    </view>
    <view class="submit-area"><t-button theme="primary" block="{{true}}" loading="{{isSubmitting}}" bind:tap="onSubmit">提交反馈</t-button></view>
  </scroll-view>
</view>