.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.profile-header{display:flex;align-items:center;gap:20rpx;padding:32rpx;background:var(--card-bg);margin:16rpx 24rpx;border-radius:var(--radius-lg)}.avatar{width:100rpx;height:100rpx;border-radius:50%}.avatar.default{background:var(--accent-color);display:flex;justify-content:center;align-items:center;color:#fff;font-size:36rpx;font-weight:700}.nickname{font-size:32rpx;font-weight:700}.empty{padding:80rpx 0}.post-list{padding:0 24rpx}.post-card{background:var(--card-bg);border-radius:var(--radius-md);padding:20rpx 24rpx;margin-bottom:12rpx}.post-content{font-size:28rpx;line-height:1.6;display:block;margin-bottom:8rpx}.post-images{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:8rpx}.post-img{width:200rpx;height:200rpx;border-radius:8rpx}.post-footer{display:flex;justify-content:space-between;align-items:center}.post-time{font-size:22rpx;color:var(--text-secondary)}.post-delete{padding:8rpx}.fab{position:fixed;right:32rpx;bottom:120rpx;width:96rpx;height:96rpx;border-radius:50%;background:var(--accent-color);display:flex;justify-content:center;align-items:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.15);z-index:10}