<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="我的动态" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="profile-header">
      <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar" mode="aspectFill" />
      <view wx:else class="avatar default"><text>{{nickname[0]}}</text></view>
      <text class="nickname">{{nickname}}</text>
    </view>
    <view wx:if="{{posts.length===0}}" class="empty"><t-empty description="还没有发布动态" /></view>
    <view wx:else class="post-list">
      <view wx:for="{{posts}}" wx:key="id" class="post-card">
        <text class="post-content">{{item.content}}</text>
        <view wx:if="{{item.images.length > 0}}" class="post-images">
          <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" class="post-img" data-current="{{img}}" data-urls="{{item.images}}" bindtap="onPreviewImage" />
        </view>
        <view class="post-footer">
          <text class="post-time">{{item.createTime}}</text>
          <view class="post-delete" data-id="{{item.id}}" bindtap="onDeletePost"><t-icon name="delete" size="28rpx" color="var(--error-color)" /></view>
        </view>
      </view>
    </view>
  </scroll-view>
  <view class="fab" bindtap="goToPublish"><t-icon name="add" size="48rpx" color="#fff" /></view>
</view>