.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.toggle-section{padding:24rpx}.toggle-row{display:flex;align-items:center;gap:16rpx;padding:28rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md)}.toggle-info{flex:1;display:flex;flex-direction:column;gap:4rpx}.toggle-title{font-size:30rpx;font-weight:500}.toggle-desc{font-size:24rpx;color:var(--text-secondary)}.memory-section{padding:0 24rpx}.section-header{padding:16rpx 0}.section-title{font-size:26rpx;color:var(--text-secondary);font-weight:500}.loading-hint,.empty{display:flex;justify-content:center;padding:80rpx 0}.memory-item{display:flex;align-items:flex-start;gap:12rpx;padding:20rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:8rpx}.memory-text{flex:1;font-size:28rpx;line-height:1.5}.memory-delete{flex-shrink:0;padding:4rpx}
