<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="记忆" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="toggle-section">
      <view class="toggle-row">
        <view class="toggle-info">
          <text class="toggle-title">AI 记忆</text>
          <text class="toggle-desc">开启后 AI 会记住你的偏好和对话内容</text>
        </view>
        <t-switch checked="{{memoryEnabled}}" bind:change="onToggleMemory" />
      </view>
    </view>
    <view wx:if="{{memoryEnabled}}" class="memory-section">
      <view class="section-header">
        <text class="section-title">AI 记住的内容 ({{total}})</text>
      </view>
      <view wx:if="{{isLoading}}" class="loading-hint">
        <text>加载中...</text>
      </view>
      <view wx:elif="{{memoryItems.length === 0}}" class="empty">
        <t-empty description="暂无记忆内容" />
      </view>
      <view wx:else class="memory-list">
        <view wx:for="{{memoryItems}}" wx:key="id" class="memory-item">
          <text class="memory-text">{{item.content}}</text>
          <view class="memory-delete" data-id="{{item.id}}" bindtap="onDeleteMemory">
            <t-icon name="delete" size="32rpx" color="var(--error-color)" />
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
