<view class="code-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="top-bar">
    <view class="top-bar-right" bindtap="onShowInfo">
      <t-icon name="info-circle" size="36rpx" color="var(--accent-color)" />
      <text class="top-bar-tip">SMS by YunZhu Tech</text>
    </view>
  </view>
  <view class="code-content">
    <view class="code-hint"><text>Check your {{accountType}} to login</text></view>
    <view class="code-card">
      <view class="code-sent-info">
        <text class="code-sent-label">Code sent to</text>
        <text class="code-sent-account">{{account}}</text>
      </view>
      <view class="code-input-wrap">
        <t-input class="code-input" placeholder="{{isVerifying ? 'Verifying...' : 'Enter code'}}" placeholderStyle="color: #999; font-size: 36rpx;" value="{{codeInput}}" type="number" confirm-type="done" maxlength="{{6}}" bind:change="onCodeInput" bind:confirm="onCodeConfirm" disabled="{{isVerifying}}" />
      </view>
      <text wx:if="{{codeError}}" class="code-error">{{codeError}}</text>
    </view>
    <view class="login-btn-section">
      <t-button theme="primary" size="large" block="{{true}}" loading="{{isVerifying}}" disabled="{{!codeInput || isVerifying}}" shape="round" bind:tap="onLoginTap">{{isVerifying ? 'Verifying...' : 'Enter Lumina'}}</t-button>
    </view>
    <view class="action-row">
      <view class="action-btn {{isCountingDown || isVerifying ? 'disabled' : 'active'}}" bindtap="onResendCode">
        <text wx:if="{{isVerifying}}">Verifying...</text>
        <text wx:elif="{{isCountingDown}}">Resend({{countdownSeconds}}s)</text>
        <text wx:else>Resend code</text>
      </view>
      <text class="action-divider">|</text>
      <view class="action-btn active" bindtap="onChangeAccount"><text>Change account</text></view>
    </view>
  </view>
  <t-popup visible="{{showInfoSheet}}" placement="bottom" bind:visible-change="onCloseInfo">
    <view class="info-sheet">
      <view class="info-sheet-content">
        <text class="info-text">You may receive a verification SMS. Do not share your code.</text>
      </view>
      <view class="info-footer safe-bottom">
        <view class="info-known-btn" bindtap="onInfoKnown">OK</view>
      </view>
    </view>
  </t-popup>
</view>
