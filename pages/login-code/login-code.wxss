/**
 * 验证码登录页样式
 * 对应 Kuikly: LoginCodeScreen.kt
 */

.code-page {
  min-height: 100vh;
  background-color: var(--bg-color);
  display: flex;
  flex-direction: column;
}

.top-bar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx 32rpx;
}

.top-bar-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.top-bar-tip {
  font-size: 22rpx;
  color: var(--accent-color);
}

.code-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
  padding-bottom: 96rpx;
}

.code-hint {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-top: 60rpx;
}

/* 验证码卡片 */
.code-card {
  width: 100%;
  background-color: var(--card-bg);
  border-radius: var(--radius-lg);
  border: 1.6rpx solid var(--border-color);
  padding: 48rpx 32rpx;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-sent-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.code-sent-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.code-sent-account {
  font-size: 28rpx;
  font-weight: 700;
}

.code-input-wrap {
  width: 100%;
  margin-top: 24rpx;
}

.code-input .t-input__wrap {
  background-color: var(--bg-color) !important;
  border: 2rpx solid var(--border-color) !important;
  border-radius: 99rpx !important;
  height: 96rpx !important;
  padding: 0 40rpx !important;
}

.code-input .t-input__control {
  font-size: 36rpx !important;
  text-align: center;
}

.code-error {
  font-size: 24rpx;
  color: var(--error-color);
  margin-top: 16rpx;
  text-align: center;
}

/* 登录按钮 */
.login-btn-section {
  margin-top: 32rpx;
  width: 100%;
}

.login-btn-section t-button {
  --td-button-primary-bg-color: #000;
  --td-button-primary-border-color: #000;
  --td-button-border-radius: 99rpx;
}

/* 操作按钮 */
.action-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  font-weight: 500;
  padding: 8rpx 32rpx;
  border-radius: 99rpx;
}

.action-btn.active {
  color: var(--link-color);
}

.action-btn.disabled {
  color: #999;
}

.action-divider {
  color: #999;
  font-size: 28rpx;
}

/* 信息弹窗 */
.info-sheet {
  background-color: var(--bg-color);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.info-sheet-content {
  flex: 1;
  padding: 48rpx 32rpx;
  display: flex;
  justify-content: center;
}

.info-text {
  font-size: 28rpx;
  text-align: center;
  line-height: 1.6;
}

.info-footer {
  padding: 16rpx 32rpx;
}

.info-known-btn {
  background-color: #000;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 99rpx;
}
