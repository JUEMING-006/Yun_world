.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.form{padding:24rpx}.avatar-section{display:flex;justify-content:center;padding:32rpx 0}.avatar-wrap{width:160rpx;height:160rpx;border-radius:50%;overflow:hidden}.avatar{width:100%;height:100%}.avatar-placeholder{width:100%;height:100%;background:var(--card-bg);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:8rpx;border:2rpx dashed var(--border-color);border-radius:50%}.avatar-hint{font-size:22rpx;color:#999}.form-item{margin-bottom:32rpx}.form-label{font-size:26rpx;color:var(--text-secondary);margin-bottom:12rpx;display:block}.gender-row{display:flex;gap:16rpx}.gender-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:8rpx;padding:20rpx;border-radius:var(--radius-md);background:var(--card-bg);font-size:28rpx;border:2rpx solid transparent}.gender-btn.active{border-color:var(--accent-color)}.gender-icon{font-size:32rpx}.form-actions{margin-top:48rpx}
