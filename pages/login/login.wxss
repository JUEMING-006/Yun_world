/**
 * Login page styles
 * Kuikly dp = miniprogram px (1:1)
 */

.login-page {
  min-height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
}

.top-bar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 10px 16px;
}

.top-bar-right {
  display: flex;
  align-items: center;
  gap: 4px;
}

.top-bar-tip {
  font-size: 11px;
  color: var(--accent-color);
}

/* Content: padding(top=statusBarHeight+120f, bottom=48f, left=32f, right=32f) */
.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 0 32px;
  padding-bottom: 48px;
  justify-content: center;
}

/* Brand: size(42f,42f), borderRadius(8f), fontSize(42f) */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.brand-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.brand-logo {
  width: 42px;
  height: 42px;
  border-radius: 8px;
  margin-right: 8px;
}

.brand-title {
  font-size: 42px;
  font-weight: 700;
}

.brand-subtitle {
  font-size: 36px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 36px;
}

.gradient-text {
  background: linear-gradient(to right, #AD37FE, #23D3FD);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Input: height(48f), fontSize(20f), borderRadius(99f) */
.input-section {
  margin-top: 6px;
}

.account-input .t-input__wrap {
  background-color: transparent !important;
  border: 1px solid var(--border-color) !important;
  border-radius: 999px !important;
  height: 48px !important;
  padding: 0 20px !important;
}

.account-input .t-input__control {
  font-size: 20px !important;
  color: #000 !important;
  text-align: center;
  font-weight: 500;
}

.submit-section {
  margin-top: 8px;
}

.submit-section t-button {
  --td-button-primary-bg-color: #000;
  --td-button-primary-border-color: #000;
  --td-button-border-radius: 999px;
}

/* Agreement: marginTop(12f) */
.agreement-row {
  display: flex;
  justify-content: center;
  margin-top: 12px;
}

.agreement-check {
  display: flex;
  align-items: center;
  gap: 6px;
}

.checkbox {
  width: 16px;
  height: 16px;
  border-radius: 5px;
  border: 1px solid var(--border-color);
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #fff;
  flex-shrink: 0;
}

.checkbox.checked {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
}

.check-icon {
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  line-height: 1;
}

.agreement-text {
  font-size: 14px;
  color: #999;
}

.agreement-link {
  font-size: 14px;
  color: var(--accent-color);
  font-weight: 700;
  text-decoration: underline;
}

/* Agreement sheet */
.agreement-sheet {
  background-color: #fff;
  border-radius: 32px 32px 0 0;
  height: 60vh;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12px 16px;
  gap: 8px;
}

.sheet-header-title {
  font-size: 14px;
  font-weight: 700;
  background-color: #fff;
  border-radius: 999px;
  padding: 8px 10px;
  box-shadow: 0 0 10px #f0f0ee;
}

.sheet-header-spacer { flex: 1; }

.sheet-close-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 10px #f0f0ee;
}

.agreement-list {
  flex: 1;
  padding: 12px 16px;
  overflow-y: auto;
}

.agreement-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 0;
  border-bottom: 1px solid #eee;
}

.agreement-item-title {
  flex: 1;
  font-size: 15px;
  color: #333;
}

.sheet-footer {
  padding: 8px 16px;
}

.agree-btn {
  background-color: #000;
  color: #fff;
  font-size: 18px;
  font-weight: 700;
  text-align: center;
  padding: 12px 0;
  border-radius: 999px;
}
