.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.list{padding:24rpx}.item{display:flex;align-items:center;gap:16rpx;padding:28rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:2rpx}.item.danger .item-title{color:var(--error-color)}.item-info{flex:1;display:flex;flex-direction:column;gap:4rpx}.item-title{font-size:30rpx;font-weight:500}.item-desc{font-size:24rpx;color:var(--text-secondary)}
