.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.hero{text-align:center;padding:48rpx 32rpx;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff}.hero-title{font-size:48rpx;font-weight:700;display:block}.hero-desc{font-size:26rpx;opacity:0.9;display:block;margin-top:8rpx}.compare-table{margin:24rpx;background:var(--card-bg);border-radius:var(--radius-lg);overflow:hidden}.table-header,.table-row{display:flex;padding:20rpx 24rpx;border-bottom:1rpx solid var(--divider-color)}.table-header{background:var(--bg-color);font-weight:700;font-size:26rpx}.col-feature{flex:2;font-size:26rpx}.col-free,.col-plus{flex:1;text-align:center;font-size:26rpx}.col-plus{color:var(--accent-color);font-weight:500}.subscribe-area{padding:32rpx}