.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1;padding:16rpx 24rpx}.style-list{margin-bottom:32rpx}.style-card{display:flex;justify-content:space-between;align-items:center;padding:28rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:12rpx;border:2rpx solid transparent}.style-card.active{border-color:var(--accent-color)}.style-info{display:flex;flex-direction:column;gap:4rpx}.style-name{font-size:30rpx;font-weight:500}.style-desc{font-size:24rpx;color:var(--text-secondary)}.save-area{padding:0 24rpx}