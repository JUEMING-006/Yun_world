<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="AI 伴侣风格" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="style-list">
      <view wx:for="{{styles}}" wx:key="id" class="style-card {{currentStyle===item.id?'active':''}}" data-id="{{item.id}}" bindtap="onStyleSelect">
        <view class="style-info"><text class="style-name">{{item.name}}</text><text class="style-desc">{{item.desc}}</text></view>
        <t-icon wx:if="{{currentStyle===item.id}}" name="check" size="36rpx" color="var(--accent-color)" />
      </view>
    </view>
    <view class="save-area"><t-button theme="primary" block="{{true}}" loading="{{isSaving}}" bind:tap="onSave">保存设置</t-button></view>
  </scroll-view>
</view>