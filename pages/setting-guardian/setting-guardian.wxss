.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.info-section{display:flex;align-items:flex-start;gap:12rpx;padding:24rpx;margin:16rpx 24rpx;background:rgba(74,144,217,0.08);border-radius:var(--radius-md)}.info-text{font-size:26rpx;color:var(--text-secondary);line-height:1.5}.menu-list{margin:0 24rpx}.menu-item{display:flex;justify-content:space-between;align-items:center;padding:28rpx 24rpx;background:var(--card-bg);border-bottom:1rpx solid var(--divider-color)}.item-left{display:flex;align-items:center;gap:12rpx}.section-title{font-size:26rpx;color:var(--text-secondary);padding:24rpx 24rpx 8rpx}.member-list{padding:0 24rpx}.member-card{display:flex;justify-content:space-between;padding:20rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md);margin-bottom:8rpx}.member-name{font-size:28rpx;font-weight:500}.member-relation{font-size:24rpx;color:var(--text-secondary)}.invite-sheet{padding:32rpx;background:var(--bg-color);border-radius:32rpx 32rpx 0 0}.sheet-title{font-size:34rpx;font-weight:700;display:block;margin-bottom:24rpx}.form-item{margin-bottom:24rpx}.form-label{font-size:26rpx;color:var(--text-secondary);margin-bottom:8rpx;display:block}.option-row{display:flex;gap:12rpx;margin-bottom:12rpx}.option-btn{padding:12rpx 24rpx;border-radius:99rpx;background:var(--card-bg);font-size:26rpx;border:2rpx solid transparent}.option-btn.active{border-color:var(--accent-color);color:var(--accent-color)}