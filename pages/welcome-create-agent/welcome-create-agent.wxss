/**
 * 创建智能体引导页样式
 * 分步式表单：名称 → 性格 → 性别确认
 */

.agent-create-page {
  min-height: 100vh;
  background-color: var(--bg-color);
}

.page-content {
  padding: 0 48rpx;
  padding-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── 品牌 ── */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.brand-title {
  font-size: 64rpx;
  font-weight: 700;
}

.brand-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

/* ── 步骤指示器 ── */
.steps {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 48rpx;
  width: 100%;
  justify-content: center;
}

.step {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--card-bg);
  border: 2rpx solid var(--border-color);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.step.active {
  background-color: var(--accent-color);
  border-color: var(--accent-color);
  color: #fff;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background-color: var(--border-color);
}

.step-line.active {
  background-color: var(--accent-color);
}

/* ── 步骤内容 ── */
.step-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
}

.step-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 32rpx;
}

.step-hint {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 16rpx;
}

/* ── 表单字段 ── */
.form-field {
  width: 100%;
  margin-top: 24rpx;
  background-color: var(--card-bg-input);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.form-field .t-input__wrap,
.form-field .t-textarea__wrap {
  background-color: transparent !important;
  border: none !important;
  padding: 16rpx 24rpx !important;
}

/* ── 性格标签 ── */
.personality-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 16rpx;
}

.personality-tag {
  padding: 16rpx 32rpx;
  border-radius: 99rpx;
  background-color: var(--card-bg);
  border: 2rpx solid var(--border-color);
  font-size: 28rpx;
}

.personality-tag.selected {
  background-color: var(--accent-color);
  border-color: var(--accent-color);
  color: #fff;
}

/* ── 性别选择 ── */
.gender-row {
  display: flex;
  gap: 24rpx;
  width: 100%;
  justify-content: center;
  margin-bottom: 32rpx;
}

.gender-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background-color: var(--card-bg);
  border: 2rpx solid var(--border-color);
  font-size: 28rpx;
}

.gender-btn.active {
  border-color: var(--accent-color);
  background-color: rgba(74, 144, 217, 0.1);
}

.gender-icon {
  font-size: 48rpx;
}

/* ── 预览卡片 ── */
.preview-card {
  width: 100%;
  background-color: var(--card-bg);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-color);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.preview-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--accent-color);
  display: flex;
  justify-content: center;
  align-items: center;
}

.preview-avatar-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.preview-name {
  font-size: 32rpx;
  font-weight: 700;
}

.preview-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* ── 操作按钮 ── */
.actions {
  width: 100%;
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.btn-back {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--border-color);
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  flex: 2;
  text-align: center;
  padding: 24rpx 0;
  border-radius: var(--radius-xl);
  background-color: #000;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}
