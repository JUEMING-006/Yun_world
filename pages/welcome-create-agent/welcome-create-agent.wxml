<!--
  创建智能体引导页（分步式）
  对应 Kuikly: WelcomeCreateAgentScreen.kt + AgentCreateViewModel.kt
-->
<view class="agent-create-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="page-content">

    <!-- 品牌标识 -->
    <view class="brand-section">
      <text class="brand-title gradient-text">Lumina</text>
      <text class="brand-subtitle">创建你的专属 AI 伙伴</text>
    </view>

    <!-- 步骤指示器 -->
    <view class="steps">
      <view class="step {{currentStep >= 1 ? 'active' : ''}}">1</view>
      <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="step {{currentStep >= 2 ? 'active' : ''}}">2</view>
      <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
      <view class="step {{currentStep >= 3 ? 'active' : ''}}">3</view>
    </view>

    <!-- 步骤1：输入名称 -->
    <view wx:if="{{currentStep === 1}}" class="step-content">
      <text class="step-title">给你的 AI 伙伴起个名字</text>
      <view class="form-field">
        <t-input
          placeholder="例如：小助手、Lumina..."
          value="{{agentName}}"
          maxlength="{{20}}"
          bind:change="onNameInput"
        />
      </view>
      <text class="step-hint">名字是你和 AI 之间的专属称呼</text>
    </view>

    <!-- 步骤2：选择性格 -->
    <view wx:elif="{{currentStep === 2}}" class="step-content">
      <text class="step-title">选择性格特点</text>
      <text class="step-desc">可多选，让你的 AI 更懂你</text>
      <view class="personality-grid">
        <view
          wx:for="{{personalityPresets}}"
          wx:key="id"
          class="personality-tag {{item.selected ? 'selected' : ''}}"
          data-id="{{item.id}}"
          bindtap="onTogglePersonality"
        >
          <text>{{item.label}}</text>
        </view>
      </view>

      <text class="step-title" style="margin-top: 32rpx;">补充描述（可选）</text>
      <view class="form-field">
        <t-textarea
          placeholder="例如：喜欢用温柔的语气交流，擅长心理学..."
          value="{{agentDescription}}"
          maxlength="{{200}}"
          bind:change="onDescInput"
        />
      </view>
    </view>

    <!-- 步骤3：选择性别 + 确认 -->
    <view wx:elif="{{currentStep === 3}}" class="step-content">
      <text class="step-title">选择性别</text>
      <view class="gender-row">
        <view
          wx:for="{{genderOptions}}"
          wx:key="id"
          class="gender-btn {{agentGender === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onGenderSelect"
        >
          <text class="gender-icon">{{item.icon}}</text>
          <text>{{item.label}}</text>
        </view>
      </view>

      <!-- 预览卡片 -->
      <view class="preview-card">
        <view class="preview-avatar">
          <text class="preview-avatar-text">{{agentName[0] || 'A'}}</text>
        </view>
        <text class="preview-name">{{agentName}}</text>
        <text class="preview-desc">{{agentDescription || '很高兴认识你！'}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <view wx:if="{{currentStep > 1}}" class="btn-back" bindtap="onPrevStep">
        <text>上一步</text>
      </view>

      <view wx:if="{{currentStep < 3}}" class="btn-primary" bindtap="onNextStep">
        <text>下一步</text>
      </view>

      <view wx:else class="btn-primary" bindtap="onCreateAgent">
        <text wx:if="{{isCreating}}">创建中...</text>
        <text wx:else>创建智能体</text>
      </view>
    </view>

  </view>
</view>
