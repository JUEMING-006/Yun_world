<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="{{testName}}" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="messages" scroll-y scroll-into-view="msg-{{messages.length-1}}">
    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="msg-item {{item.type}}">
      <text class="msg-text">{{item.content}}</text>
    </view>
  </scroll-view>
  <view wx:if="{{currentQuestion}}" class="question-panel">
    <view class="progress"><text>{{currentIndex + 1}} / {{totalQuestions}}</text></view>
    <text class="question-text">{{currentQuestion.questionText}}</text>
    <!-- 量表/单选 -->
    <view wx:if="{{currentQuestion.questionType === 'scale' || currentQuestion.questionType === 'single_choice'}}" class="options-scroll">
      <scroll-view scroll-x class="options-row">
        <view wx:for="{{currentQuestion.options}}" wx:key="index" class="option-card" data-value="{{item.value || item.index}}" data-text="{{item.text}}" bindtap="onAnswerSelect">
          <text>{{item.text}}</text>
        </view>
      </scroll-view>
    </view>
    <!-- 多选 -->
    <view wx:elif="{{currentQuestion.questionType === 'multiple_choice'}}" class="options-grid">
      <view wx:for="{{currentQuestion.options}}" wx:key="index" class="option-card" data-value="{{item.value || item.index}}" data-text="{{item.text}}" bindtap="onAnswerSelect">
        <text>{{item.text}}</text>
      </view>
    </view>
    <!-- 文本输入 -->
    <view wx:else class="text-answer">
      <input class="text-input" placeholder="请输入你的回答..." value="{{textAnswer}}" bindinput="onTextAnswer" bindconfirm="onSubmitTextAnswer" />
      <t-button size="small" theme="primary" bind:tap="onSubmitTextAnswer" disabled="{{!textAnswer}}">提交</t-button>
    </view>
  </view>
  <view wx:if="{{isCompleted}}" class="completed-bar"><text>测评已完成，正在跳转...</text></view>
</view>