.page{min-height:100vh;background:#f9f9f7;display:flex;flex-direction:column}.messages{flex:1;padding:16rpx 24rpx;padding-bottom:400rpx}.msg-item{margin-bottom:16rpx;max-width:80%}.msg-item.user{margin-left:auto;background:var(--accent-color);color:#fff;border-radius:24rpx 24rpx 4rpx 24rpx;padding:16rpx 24rpx}.msg-item.system{margin:auto;background:var(--card-bg);color:var(--text-secondary);border-radius:12rpx;padding:12rpx 24rpx;font-size:24rpx;text-align:center}.msg-text{font-size:28rpx;line-height:1.5}.question-panel{position:fixed;bottom:0;left:0;right:0;background:var(--bg-color);border-radius:32rpx 32rpx 0 0;padding:24rpx 32rpx;box-shadow:0 -4rpx 24rpx rgba(0,0,0,0.06);padding-bottom:calc(24rpx + env(safe-area-inset-bottom))}.progress{font-size:24rpx;color:var(--text-secondary);margin-bottom:12rpx}.question-text{font-size:30rpx;font-weight:500;margin-bottom:20rpx;display:block}.options-scroll{margin-bottom:12rpx}.options-row{white-space:nowrap}.options-row .option-card{display:inline-block;padding:20rpx 32rpx;background:var(--card-bg);border-radius:99rpx;margin-right:16rpx;font-size:26rpx;border:2rpx solid var(--border-color)}.options-grid{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:12rpx}.options-grid .option-card{padding:16rpx 24rpx;background:var(--card-bg);border-radius:12rpx;font-size:26rpx;border:2rpx solid var(--border-color)}.text-answer{display:flex;gap:12rpx;align-items:center}.text-input{flex:1;height:72rpx;border:2rpx solid var(--border-color);border-radius:12rpx;padding:0 24rpx;font-size:28rpx}.completed-bar{text-align:center;padding:24rpx;font-size:26rpx;color:var(--success-color)}