.welcome-page {
  min-height: 100vh;
  background-color: var(--bg-color);
}

.welcome-content {
  padding: 0 48rpx;
  padding-top: 120rpx;
}

.welcome-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.welcome-title {
  font-size: 72rpx;
  font-weight: 700;
}

.welcome-subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.form-section {
  padding: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 生日输入 */
.birthday-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.birthday-field {
  flex: 1;
  background-color: var(--card-bg-input);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.birthday-field.short {
  flex: 0.6;
}

.birthday-field .t-input__wrap {
  background-color: transparent !important;
  border: none !important;
  padding: 16rpx 20rpx !important;
  height: 80rpx !important;
}

.birthday-sep {
  font-size: 36rpx;
  color: var(--text-secondary);
}

/* 昵称 */
.nickname-field {
  background-color: var(--card-bg-input);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.nickname-field .t-input__wrap {
  background-color: transparent !important;
  border: none !important;
  padding: 16rpx 20rpx !important;
  height: 80rpx !important;
}

/* 操作按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.btn-skip {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--border-color);
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 500;
}

.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-xl);
  background-color: #000;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

/* 成功状态 */
.success-icon {
  display: flex;
  justify-content: center;
  margin: 60rpx 0 24rpx;
}

.success-text {
  text-align: center;
  font-size: 34rpx;
  color: var(--success-color);
  font-weight: 500;
}
