<!--
  欢迎页 — 年龄验证 + 昵称
  对应 Kuikly: WelcomeScreen.kt body()
-->
<view class="welcome-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="welcome-content">

    <!-- 品牌标识 -->
    <view class="welcome-brand">
      <text class="welcome-title gradient-text">Lumina</text>
      <text class="welcome-subtitle">让我们更了解你</text>
    </view>

    <!-- 年龄验证区 -->
    <view class="form-section" wx:if="{{!isAgeConfirmed}}">
      <text class="form-label">请输入你的出生日期</text>
      <view class="birthday-row">
        <view class="birthday-field">
          <t-input
            placeholder="年"
            value="{{birthdayYear}}"
            type="number"
            maxlength="{{4}}"
            bind:change="onYearInput"
          />
        </view>
        <text class="birthday-sep">/</text>
        <view class="birthday-field short">
          <t-input
            placeholder="月"
            value="{{birthdayMonth}}"
            type="number"
            maxlength="{{2}}"
            bind:change="onMonthInput"
          />
        </view>
        <text class="birthday-sep">/</text>
        <view class="birthday-field short">
          <t-input
            placeholder="日"
            value="{{birthdayDay}}"
            type="number"
            maxlength="{{2}}"
            bind:change="onDayInput"
          />
        </view>
      </view>

      <!-- 昵称 -->
      <text class="form-label" style="margin-top: 40rpx;">你想让我们怎么称呼你？（可选）</text>
      <view class="nickname-field">
        <t-input
          placeholder="请输入昵称"
          value="{{nickname}}"
          maxlength="{{20}}"
          bind:change="onNicknameInput"
        />
      </view>

      <view class="form-actions">
        <view class="btn-confirm full" bindtap="onConfirmAge">确认</view>
      </view>
    </view>

    <!-- 确认后的提交（简化流程，年龄确认后直接跳转） -->
    <view class="form-section" wx:else>
      <view class="success-icon">
        <t-icon name="check-circle" size="96rpx" color="var(--success-color)" />
      </view>
      <text class="success-text">年龄信息已确认</text>
      <view class="form-actions">
        <view class="btn-confirm" bindtap="onSubmit">继续</view>
      </view>
    </view>

  </view>
</view>
