.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.form{padding:24rpx}.form-item{margin-bottom:32rpx}.form-label{font-size:26rpx;color:var(--text-secondary);margin-bottom:12rpx;display:block}.gender-row{display:flex;gap:16rpx}.gender-btn{flex:1;text-align:center;padding:20rpx;border-radius:var(--radius-md);background:var(--card-bg);font-size:28rpx;border:2rpx solid transparent}.gender-btn.active{border-color:var(--accent-color);color:var(--accent-color)}.form-actions{margin-top:48rpx}
