<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="个性化" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="form">
      <view class="form-item">
        <text class="form-label">昵称</text>
        <t-input placeholder="请输入昵称" value="{{nickname}}" maxlength="{{20}}" bind:change="onNicknameInput" />
      </view>
      <view class="form-item">
        <text class="form-label">个人简介</text>
        <t-textarea placeholder="介绍一下自己" value="{{bio}}" maxlength="{{200}}" bind:change="onBioInput" />
      </view>
      <view class="form-item">
        <text class="form-label">性别</text>
        <view class="gender-row">
          <view wx:for="{{genderOptions}}" wx:key="id" class="gender-btn {{gender===item.id?'active':''}}" data-id="{{item.id}}" bindtap="onGenderSelect">
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="form-actions">
        <t-button theme="primary" block="{{true}}" loading="{{isSaving}}" bind:tap="onSave">保存修改</t-button>
      </view>
    </view>
  </scroll-view>
</view>
