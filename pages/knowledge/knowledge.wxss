.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.loading,.empty,.load-more{display:flex;justify-content:center;padding:48rpx 0;font-size:26rpx;color:var(--text-secondary)}.article-list{padding:24rpx}.article-card{background:var(--card-bg);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:24rpx}.article-cover{width:100%;height:300rpx}.cover-img{width:100%;height:100%}.article-info{padding:20rpx 24rpx}.article-category{font-size:22rpx;color:var(--accent-color);background:rgba(74,144,217,0.1);padding:4rpx 16rpx;border-radius:99rpx;display:inline-block;margin-bottom:8rpx}.article-title{font-size:32rpx;font-weight:700;display:block;margin-bottom:8rpx;line-height:1.4}.article-summary{font-size:26rpx;color:var(--text-secondary);display:block;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.article-meta{display:flex;gap:24rpx;margin-top:12rpx}.meta-item{display:flex;align-items:center;gap:4rpx;font-size:22rpx;color:var(--text-secondary)}
