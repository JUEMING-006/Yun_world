<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="Circle" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y bindscrolltolower="onLoadMore">
    <view wx:if="{{isLoading && posts.length===0}}" class="loading"><text>Loading...</text></view>
    <view wx:elif="{{posts.length===0}}" class="empty"><t-empty description="No posts yet" /></view>
    <view wx:else class="post-list">
      <view wx:for="{{posts}}" wx:key="id" class="post-card">
        <view class="post-header">
          <view class="post-avatar">
            <image wx:if="{{item.userAvatar}}" src="{{item.userAvatar}}" class="avatar-img" mode="aspectFill" />
            <view wx:else class="avatar-default"><text>{{item.userName[0] || 'U'}}</text></view>
          </view>
          <view class="post-user-info">
            <text class="post-nickname">{{item.userName}}</text>
            <text class="post-time">{{item.createTime}}</text>
          </view>
        </view>
        <text class="post-content">{{item.content}}</text>
        <view wx:if="{{item.images.length > 0}}" class="post-images">
          <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" class="post-img" data-current="{{img}}" data-urls="{{item.images}}" bindtap="onPreviewImage" />
        </view>
        <view class="post-actions">
          <view class="action-btn" data-id="{{item.id}}" bindtap="onLike">
            <t-icon name="heart" size="32rpx" color="{{item.isLiked ? '#FF4444' : '#999'}}" />
            <text class="{{item.isLiked ? 'liked' : ''}}">{{item.likeCount}}</text>
          </view>
          <view class="action-btn">
            <t-icon name="chat" size="32rpx" color="#999" />
            <text>{{item.commentCount}}</text>
          </view>
        </view>
        <view wx:if="{{item.comments.length > 0}}" class="post-comments">
          <view wx:for="{{item.comments}}" wx:for-item="c" wx:key="commentId" class="comment-item">
            <text class="comment-user">{{c.userName}}:</text>
            <text class="comment-text">{{c.content}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Publish button -->
  <view class="fab" bindtap="onShowPublish">
    <t-icon name="add" size="48rpx" color="#fff" />
  </view>

  <!-- Publish sheet -->
  <t-popup visible="{{showPublish}}" placement="bottom" bind:visible-change="onClosePublish">
    <view class="publish-sheet">
      <view class="publish-header">
        <text class="publish-title">New Post</text>
        <view class="publish-close" bindtap="onClosePublish"><t-icon name="close" size="40rpx" /></view>
      </view>
      <view class="publish-body">
        <t-textarea placeholder="Share your thoughts..." value="{{publishContent}}" maxlength="{{500}}" bind:change="onPublishInput" />
        <view class="publish-images">
          <view wx:for="{{publishImages}}" wx:key="*this" class="publish-img-wrap">
            <image src="{{item}}" class="publish-img" mode="aspectFill" />
            <view class="publish-img-remove" data-idx="{{index}}" bindtap="onRemoveImage">
              <t-icon name="close-circle" size="32rpx" color="#fff" />
            </view>
          </view>
          <view wx:if="{{publishImages.length < 9}}" class="publish-add-img" bindtap="onChooseImages">
            <t-icon name="add" size="48rpx" color="#999" />
          </view>
        </view>
      </view>
      <view class="publish-footer safe-bottom">
        <t-button theme="primary" block="{{true}}" loading="{{isPublishing}}" bind:tap="onPublish">Publish</t-button>
      </view>
    </view>
  </t-popup>
</view>
