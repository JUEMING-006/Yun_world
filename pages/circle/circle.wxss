.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.loading,.empty,.load-more{display:flex;justify-content:center;padding:48rpx 0;font-size:26rpx;color:var(--text-secondary)}.post-list{padding:16rpx 24rpx}.post-card{background:var(--card-bg);border-radius:var(--radius-lg);padding:24rpx;margin-bottom:16rpx}.post-header{display:flex;align-items:center;gap:16rpx;margin-bottom:16rpx}.post-avatar{flex-shrink:0}.avatar-img,.avatar-default{width:72rpx;height:72rpx;border-radius:50%}.avatar-default{background:var(--accent-color);display:flex;justify-content:center;align-items:center;color:#fff;font-size:28rpx;font-weight:700}.post-user-info{flex:1;display:flex;flex-direction:column;gap:4rpx}.post-nickname{font-size:28rpx;font-weight:500}.post-time{font-size:22rpx;color:var(--text-secondary)}.post-content{font-size:30rpx;line-height:1.6;display:block;margin-bottom:12rpx}.post-images{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:12rpx}.post-img{width:200rpx;height:200rpx;border-radius:12rpx}.post-actions{display:flex;gap:32rpx;padding-top:12rpx;border-top:1rpx solid var(--divider-color)}.action-btn{display:flex;align-items:center;gap:8rpx;font-size:24rpx;color:var(--text-secondary)}.action-btn .liked{color:#FF4444}.post-comments{margin-top:12rpx;padding:12rpx;background:rgba(0,0,0,0.02);border-radius:12rpx}.comment-item{font-size:24rpx;line-height:1.5;margin-bottom:4rpx}.comment-user{color:var(--accent-color);font-weight:500}.comment-text{color:var(--text-secondary)}.fab{position:fixed;right:32rpx;bottom:120rpx;width:96rpx;height:96rpx;border-radius:50%;background:var(--accent-color);display:flex;justify-content:center;align-items:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.15);z-index:10}.publish-sheet{background:var(--bg-color);border-radius:32rpx 32rpx 0 0;max-height:80vh;display:flex;flex-direction:column}.publish-header{display:flex;justify-content:space-between;align-items:center;padding:24rpx 32rpx;border-bottom:1rpx solid var(--divider-color)}.publish-title{font-size:32rpx;font-weight:700}.publish-close{padding:8rpx}.publish-body{flex:1;padding:24rpx 32rpx;overflow-y:auto}.publish-images{display:flex;flex-wrap:wrap;gap:12rpx;margin-top:16rpx}.publish-img-wrap{position:relative;width:160rpx;height:160rpx}.publish-img{width:100%;height:100%;border-radius:12rpx}.publish-img-remove{position:absolute;top:-8rpx;right:-8rpx}.publish-add-img{width:160rpx;height:160rpx;border-radius:12rpx;border:2rpx dashed var(--border-color);display:flex;justify-content:center;align-items:center;background:var(--card-bg)}.publish-footer{padding:16rpx 32rpx}
