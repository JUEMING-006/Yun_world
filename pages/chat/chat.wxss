/**
 * Chat page styles
 * Kuikly dp = miniprogram px (1:1, NOT ×2)
 */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9f9f7;
  position: relative;
  overflow: hidden;
}

.main-content {
  display: flex;
  flex-direction: column;
  height: 100%;
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

.main-content.sidebar-open {
  transform: translateX(80%);
}

.sidebar-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.15);
  z-index: 90;
}

/* Nav bar: padding(left=12f, right=12f), height=48f+statusBarHeight */
.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1;
  padding: 0 12px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
}

.nav-bar-content {
  display: flex;
  align-items: flex-end;
  padding-top: env(safe-area-inset-top);
  height: calc(env(safe-area-inset-top) + 48px);
}

/* Menu button: size(46f,46f), marginRight=12f */
.nav-btn {
  width: 46px;
  height: 46px;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.nav-btn.placeholder { visibility: hidden; }

.menu-btn {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  margin-right: 12px;
  box-shadow: 0 0 10px #f0f0ee;
}

/* Agent button: height(46f), cornerRadius=99f */
.nav-agent-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  height: 46px;
  border-radius: 999px;
  background-color: rgba(255, 255, 255, 0.85);
  padding: 0 6px;
  box-shadow: 0 0 10px #f0f0ee;
}

.nav-agent-avatar {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.nav-agent-avatar.default {
  background-color: var(--accent-color);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
}

.nav-avatar-img { width: 100%; height: 100%; }

.nav-agent-name {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Jelly bounce */
@keyframes nav-jelly {
  0% { transform: scale(1); }
  30% { transform: scale(0.88); }
  60% { transform: scale(1.06); }
  100% { transform: scale(1); }
}

.menu-btn.jelly,
.nav-agent-btn.jelly {
  animation: nav-jelly 0.26s ease-out;
}

/* Message list: paddingBottom(80f) */
.message-list {
  flex: 1;
  height: 0;
  overflow: hidden;
  padding-top: calc(env(safe-area-inset-top) + 56px);
  padding-bottom: 8px;
}

.message-item { margin-bottom: 2px; }

.list-bottom-spacer { height: 100px; }

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 4px;
  padding: 8px 0;
}

.loading-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid #ddd;
  border-top-color: var(--accent-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.load-more-hint {
  display: flex;
  justify-content: center;
  padding: 8px 0;
}

.load-more-text {
  font-size: 12px;
  color: #999;
}

/* ═══ Bottom input bar ═══ */
/* Kuikly: cornerRadius=30f, bg=#f9f9f7, padding=8f, margin(bottom=20f) */
@keyframes jelly-bounce {
  0% { transform: scale(1); }
  15% { transform: scale(0.94); }
  40% { transform: scale(1.05); }
  65% { transform: scale(0.98); }
  100% { transform: scale(1); }
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 200;
  padding: 0 8px;
  margin-bottom: 20px;
  padding-bottom: env(safe-area-inset-bottom);
}

.pending-image-bar {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 8px;
  margin-bottom: 4px;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 8px;
}

.pending-image-wrap {
  position: relative;
  width: 48px;
  height: 48px;
  flex-shrink: 0;
}

.pending-image {
  width: 100%;
  height: 100%;
  border-radius: 8px;
}

.pending-image-remove {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background-color: #FF4444;
  display: flex;
  justify-content: center;
  align-items: center;
}

.pending-image-hint {
  font-size: 13px;
  color: var(--text-secondary);
}

/* Mode tags */
.mode-tags {
  display: flex;
  gap: 4px;
  margin-bottom: 4px;
  padding: 0 2px;
}

.mode-tag {
  display: flex;
  align-items: center;
  gap: 2px;
  padding: 3px 8px;
  border-radius: 999px;
  background-color: #fff;
  font-size: 12px;
  color: #666;
  box-shadow: 0 0 5px #f0f0ee;
}

.mode-tag.active {
  background-color: var(--accent-color);
  color: #fff;
}

/* Input row: borderRadius=30f, padding=8f */
.input-row {
  display: flex;
  align-items: flex-end;
  gap: 4px;
  background-color: #f9f9f7;
  border-radius: 30px;
  padding: 8px;
  box-shadow: 0 0 10px #f0f0ee;
}

/* Attach button: size(42f,42f), borderRadius(99f), bg=#eff0eb */
.attach-btn {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  background-color: #eff0eb;
  border-radius: 50%;
}

/* Input: flex(1f), borderRadius(22.5f), margin(left=6f, right=6f) */
.input-wrap {
  flex: 1;
  background-color: #fff;
  border-radius: 22px;
  margin: 0 6px;
  min-height: 42px;
  max-height: 85px;
  overflow: hidden;
}

.text-input .t-input__wrap {
  background-color: transparent !important;
  border: none !important;
  padding: 0 6px !important;
  min-height: 42px !important;
}

.text-input .t-input__control {
  font-size: 16px !important;
  color: #333 !important;
  font-weight: 500 !important;
}

/* Send button: size(42f,42f), borderRadius(99f) */
.send-btn {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background-color: #999;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  transition: background-color 0.2s;
}

.send-btn.active {
  background-color: #000;
}

.send-btn.jelly-bounce {
  animation: jelly-bounce 0.3s ease-out;
}
