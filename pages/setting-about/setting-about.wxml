<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="关于" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view class="logo-section">
      <image class="logo" src="/images/logo_lumina_v1.png" mode="aspectFit" />
      <text class="app-name gradient-text">Lumina</text>
      <text class="version">v{{version}} ({{buildNumber}})</text>
    </view>
    <view class="section">
      <view class="section-title">服务</view>
      <view class="item" bindtap="onCopyServerUrl">
        <text class="item-label">服务器地址</text>
        <text class="item-value">{{serverUrl}}</text>
        <t-icon name="copy" size="32rpx" color="#999" />
      </view>
    </view>
    <view class="section">
      <view class="section-title">法律信息</view>
      <view class="item" bindtap="onOpenPrivacy">
        <text class="item-label">用户隐私协议</text>
        <t-icon name="chevron-right" size="32rpx" color="#999" />
      </view>
      <view class="item" bindtap="onOpenRegistration">
        <text class="item-label">通行证注册协议</text>
        <t-icon name="chevron-right" size="32rpx" color="#999" />
      </view>
    </view>
    <view class="footer">
      <text>© 2026 Lumina. All rights reserved.</text>
    </view>
  </scroll-view>
</view>
