.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.loading,.empty,.load-more{display:flex;justify-content:center;padding:48rpx 0;font-size:26rpx;color:var(--text-secondary)}.memory-list{padding:24rpx}.total{font-size:24rpx;color:var(--text-secondary);margin-bottom:16rpx}.memory-card{background:var(--card-bg);border-radius:var(--radius-md);padding:24rpx;margin-bottom:12rpx}.memory-content{font-size:28rpx;line-height:1.6;display:block}.memory-topics{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:12rpx}.topic-tag{font-size:22rpx;background:rgba(74,144,217,0.1);color:var(--accent-color);padding:4rpx 16rpx;border-radius:99rpx}.memory-footer{display:flex;justify-content:space-between;align-items:center;margin-top:12rpx}.memory-time{font-size:22rpx;color:var(--text-placeholder)}.memory-copy{padding:8rpx}
