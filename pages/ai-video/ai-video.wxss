.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.loading,.empty{display:flex;justify-content:center;padding:80rpx 0;font-size:26rpx;color:var(--text-secondary)}.video-list{padding:16rpx 24rpx}.video-card{background:var(--card-bg);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:24rpx}.video-thumb{width:100%;height:360rpx;position:relative}.thumb-img{width:100%;height:100%}.status-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;justify-content:center;align-items:center;color:#fff;font-size:28rpx}.play-btn{position:absolute;inset:0;display:flex;justify-content:center;align-items:center}.video-info{padding:20rpx 24rpx}.video-prompt{font-size:28rpx;display:block;margin-bottom:8rpx}.video-meta{display:flex;justify-content:space-between;margin-bottom:8rpx}.meta-text{font-size:22rpx;color:var(--text-secondary)}.status-text{font-size:22rpx;font-weight:500}.status-text.completed{color:var(--success-color)}.status-text.failed{color:var(--error-color)}.error-msg{font-size:22rpx;color:var(--error-color);margin-bottom:8rpx}.video-actions{display:flex;gap:24rpx}.action-btn{display:flex;align-items:center;gap:4rpx;font-size:24rpx;color:var(--text-secondary)}.action-btn.danger{color:var(--error-color)}.fab{position:fixed;right:32rpx;bottom:120rpx;width:96rpx;height:96rpx;border-radius:50%;background:var(--accent-color);display:flex;justify-content:center;align-items:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.15);z-index:10}.create-sheet{padding:32rpx;background:var(--bg-color);border-radius:32rpx 32rpx 0 0}.sheet-title{font-size:34rpx;font-weight:700;margin-bottom:24rpx}.form-item{margin-bottom:24rpx}.form-label{font-size:26rpx;color:var(--text-secondary);margin-bottom:8rpx;display:block}.source-img{width:160rpx;height:160rpx;border-radius:12rpx;overflow:hidden;margin-bottom:8rpx}.source-preview{width:100%;height:100%}.add-img-btn{width:160rpx;height:160rpx;border-radius:12rpx;border:2rpx dashed var(--border-color);display:flex;justify-content:center;align-items:center;background:var(--card-bg)}.option-row{display:flex;gap:16rpx}.option-btn{padding:16rpx 32rpx;border-radius:99rpx;background:var(--card-bg);font-size:26rpx;border:2rpx solid transparent}.option-btn.active{border-color:var(--accent-color);color:var(--accent-color)}