.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.info-card{margin:24rpx;padding:24rpx;background:var(--card-bg);border-radius:var(--radius-md)}.info-row{display:flex;justify-content:space-between;padding:12rpx 0;border-bottom:1rpx solid var(--divider-color)}.info-row:last-child{border-bottom:none}.info-label{font-size:28rpx;color:var(--text-secondary)}.info-value{font-size:28rpx;font-weight:500}.action-list{margin:24rpx}.action-item{display:flex;align-items:center;gap:16rpx;padding:28rpx 24rpx;background:var(--card-bg);border-radius:var(--radius-md)}.action-item.danger text{color:var(--error-color)}