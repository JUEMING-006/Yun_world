.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1}.loading{display:flex;justify-content:center;padding:80rpx 0}.report{padding:24rpx 32rpx}.report-header{text-align:center;padding:48rpx 0;border-bottom:1rpx solid var(--divider-color);margin-bottom:32rpx}.report-title{font-size:36rpx;font-weight:700;display:block;margin-bottom:24rpx}.score-circle{width:160rpx;height:160rpx;border-radius:50%;background:var(--card-bg);display:flex;flex-direction:column;justify-content:center;align-items:center;margin:0 auto 16rpx}.score-num{font-size:48rpx;font-weight:700;color:var(--accent-color)}.score-label{font-size:22rpx;color:var(--text-secondary)}.overall-level{font-size:28rpx;font-weight:500}.section{margin-bottom:32rpx}.section-title{font-size:30rpx;font-weight:700;display:block;margin-bottom:16rpx}.section-body{font-size:28rpx;line-height:1.7;color:var(--text-secondary)}.dimension-item{margin-bottom:20rpx}.dim-header{display:flex;justify-content:space-between;margin-bottom:8rpx}.dim-name{font-size:26rpx}.dim-score{font-size:26rpx;font-weight:500}.dim-bar{height:12rpx;background:var(--card-bg);border-radius:6rpx;overflow:hidden;margin-bottom:4rpx}.dim-fill{height:100%;background:var(--accent-color);border-radius:6rpx}.dim-level{font-size:22rpx;color:var(--text-secondary)}.suggestion-item{padding:16rpx 20rpx;background:var(--card-bg);border-radius:12rpx;margin-bottom:8rpx;font-size:26rpx;line-height:1.5}