.page{min-height:100vh;background:var(--bg-color)}.nav{display:flex;align-items:center;justify-content:space-between;padding:16rpx 24rpx;border-bottom:1rpx solid var(--divider-color)}.nav-back{padding:8rpx}.nav-title{font-size:32rpx;font-weight:700}.nav-publish{padding:12rpx 32rpx;border-radius:99rpx;background:#ccc;color:#fff;font-size:28rpx;font-weight:500}.nav-publish.active{background:var(--accent-color)}.body{padding:24rpx 32rpx}.image-grid{display:flex;flex-wrap:wrap;gap:16rpx;margin-top:24rpx}.img-wrap{width:200rpx;height:200rpx;border-radius:12rpx;position:relative;overflow:hidden}.preview-img{width:100%;height:100%}.img-remove{position:absolute;top:4rpx;right:4rpx}.add-img{width:200rpx;height:200rpx;border-radius:12rpx;border:2rpx dashed var(--border-color);display:flex;justify-content:center;align-items:center;background:var(--card-bg)}