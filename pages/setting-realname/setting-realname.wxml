<view class="page" style="padding-top:{{statusBarHeight}}px;">
  <top-bar title="实名认证" show-back="{{true}}" bind:back="onBack" />
  <scroll-view class="content" scroll-y>
    <view wx:if="{{isVerified}}" class="verified"><t-icon name="check-circle" size="80rpx" color="var(--success-color)" /><text class="verified-text">已通过实名认证</text></view>
    <view wx:else class="form">
      <view class="info-box"><t-icon name="info-circle" size="32rpx" color="var(--accent-color)" /><text class="info-text">实名认证后可使用更多功能，如未成年人监管、慈善信件查看等</text></view>
      <view class="form-item"><text class="form-label">真实姓名</text><t-input placeholder="请输入真实姓名" value="{{realName}}" bind:change="onNameInput" /></view>
      <view class="form-item"><text class="form-label">身份证号</text><t-input placeholder="请输入18位身份证号" value="{{idCard}}" maxlength="{{18}}" bind:change="onIdCardInput" /></view>
      <t-button theme="primary" block="{{true}}" loading="{{isSubmitting}}" bind:tap="onSubmit" style="margin-top:32rpx">提交认证</t-button>
    </view>
  </scroll-view>
</view>