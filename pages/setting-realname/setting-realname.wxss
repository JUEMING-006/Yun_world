.page{min-height:100vh;background:var(--bg-color);display:flex;flex-direction:column}.content{flex:1;padding:24rpx 32rpx}.verified{display:flex;flex-direction:column;align-items:center;padding:80rpx 0}.verified-text{font-size:32rpx;font-weight:500;color:var(--success-color);margin-top:16rpx}.info-box{display:flex;align-items:flex-start;gap:12rpx;padding:20rpx;background:rgba(74,144,217,0.08);border-radius:var(--radius-md);margin-bottom:32rpx}.info-text{font-size:26rpx;color:var(--text-secondary);line-height:1.5}.form-item{margin-bottom:24rpx}.form-label{font-size:26rpx;color:var(--text-secondary);margin-bottom:8rpx;display:block}