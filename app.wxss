/**
 * Lumina 全局样式（响应式）
 *
 * 响应式策略：
 * - 宽度方向：rpx（自动适配屏幕宽度）或 %
 * - 高度方向：flex 弹性布局 + vh 视口单位
 * - 字号：px（系统自动根据屏幕密度缩放）
 * - 间距：用 % 相对于父容器，或 vw 相对于屏幕宽度
 * - 圆角：px（固定像素，视觉一致性）
 */

page {
  /* 主色调 */
  --primary-color: #c15f3c;
  --accent-color: #4A90D9;

  /* 背景 */
  --bg-color: #ffffff;
  --bg-chat: #f9f9f7;
  --card-bg: #f3f3f3;
  --card-bg-input: #f5f5f5;
  --card-bg-button: #f5f5f5;

  /* 文字 */
  --text-primary: #333333;
  --text-secondary: #5C5C5C;
  --text-placeholder: #999999;

  /* 边框 & 分割线 */
  --border-color: #dad9d4;
  --divider-color: #eeeeee;
  --border-bottom-bar: #c5c5c3;

  /* 阴影 & 透明色 */
  --shadow-color: #f0f0ee;
  --mask-color: rgba(0, 0, 0, 0.25);
  --white-a9f: rgba(249, 250, 247, 0.95);
  --white-a85f: rgba(249, 250, 247, 0.85);

  /* 功能色 */
  --success-color: #0cd053;
  --alert-color: #fd5c06;
  --error-color: #FF4444;
  --blue-color: #61aaf2;
  --link-color: #3681d4;

  /* 聊天专用 */
  --chat-user-bubble-bg: #efefed;
  --chat-bottom-bar-bg: #eff0eb;
}

/* ── 全局 Reset ── */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 15px;
  color: var(--text-primary);
  background-color: var(--bg-color);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
}

view, text, image, scroll-view, input, button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: inherit;
}

button::after {
  border: none;
}

/* ── 通用工具类 ── */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: 700;
}

.text-medium {
  font-weight: 500;
}

.text-secondary {
  color: var(--text-secondary);
}

.text-accent {
  color: var(--accent-color);
}

.text-primary {
  color: var(--primary-color);
}

.text-link {
  color: var(--link-color);
}

.text-error {
  color: var(--error-color);
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(to right, #AD37FE, #23D3FD);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 卡片样式 */
.card {
  background-color: var(--card-bg);
  border-radius: 16px;
  padding: 4%;
}

/* 安全区域底部 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
